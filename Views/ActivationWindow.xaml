<Window x:Class="LatexStudio.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ativação do Latex Studio" Height="500" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F1F5F9" WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="16" Background="White" Padding="32,40">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="🔒" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="ATIVAR SOFTWARE" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Vincule a sua máquina para desbloquear todas as funcionalidades." Foreground="#64748B" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1">
                <!-- Device ID Section -->
                <TextBlock Text="O SEU DEVICE ID" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,6" />
                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,24">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="COPIAR" Click="OnCopyId" Background="Transparent" Foreground="#0D9488" BorderThickness="0" Cursor="Hand" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DeviceIdText" Text="ABCD-1234-EFGH" FontWeight="Bold" FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas"/>
                    </DockPanel>
                </Border>

                <!-- License Key Section -->
                <TextBlock Text="CHAVE DE LICENÇA" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LicenseInput" Height="44" TextWrapping="NoWrap" Padding="12,0" BorderBrush="#E2E8F0" VerticalContentAlignment="Center" FontSize="13" Background="#F8FAFC">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Grid.Column="1" Content="📁" Click="OnLoadLicenseFile" Width="44" Height="44" Margin="8,0,0,0" ToolTip="Carregar ficheiro .lic" Background="#F1F5F9" Foreground="#64748B" BorderBrush="#E2E8F0" BorderThickness="1">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2">
                <Button Content="ATIVAR AGORA" Click="OnActivate" Height="48" Background="#0D9488" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" FontSize="14">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                
                <Button Content="Sair da aplicação" Click="OnExit" Margin="0,16,0,0" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
