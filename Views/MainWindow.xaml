<Window x:Class="LatexStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:LatexStudio.Models"
        xmlns:vm="clr-namespace:LatexStudio.ViewModels"
        xmlns:conv="clr-namespace:LatexStudio.Core.Converters;assembly=LatexStudio.Core"
        Title="Latex Studio"
        Icon="pack://application:,,,/latexStudio.ico"
        Width="1420"
        Height="900"
        MinWidth="1040"
        MinHeight="720"
        WindowState="Maximized"
        AllowDrop="True"
        Drop="OnDrop"
        Background="{DynamicResource SurfaceBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <conv:BooleanToFontWeightConverter x:Key="BooleanToFontWeightConverter" />
        <conv:IndexToPositionConverter x:Key="IndexToPos" />
        <conv:CellWidthConverter x:Key="CellWidthConverter" />

        <!-- Table Element Template -->
        <DataTemplate DataType="{x:Type models:TableElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel x:Name="TableEditorRoot" MaxWidth="1000" HorizontalAlignment="Left">
                    <TextBlock Text="Editor de Tabelas" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Título do Bloco" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <CheckBox Content="Linha de Cabeçalho" IsChecked="{Binding HasHeader}" Margin="0,0,16,0" />
                            <CheckBox Content="Usar TabularX" IsChecked="{Binding UseTabularX}" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="12" Margin="0,0,0,16">
                        <WrapPanel>
                            <Button Content="+ Linha" Command="{Binding DataContext.AddRowCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Button Content="- Linha" Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0,14,0" Height="24" />
                            <Button Content="+ Coluna" Command="{Binding DataContext.AddColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Button Content="- Coluna" Command="{Binding DataContext.RemoveColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0,14,0" Height="24" />
                            <Button Content="Merge →" Command="{Binding DataContext.MergeCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource AccentButton}" />
                            <Button Content="Merge ↓" Command="{Binding DataContext.MergeCellDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource AccentButton}" />
                            <Button Content="Split" Command="{Binding DataContext.SplitCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </WrapPanel>
                    </Border>

                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource SurfaceBrush}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="300" MaxHeight="600">
                            <ItemsControl ItemsSource="{Binding AllCells}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas Background="Transparent" Width="{Binding TotalWidth}" Height="{Binding TotalHeight}" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left">
                                            <Setter.Value><MultiBinding Converter="{StaticResource IndexToPos}"><Binding Path="ColumnIndex" /><Binding Path="DataContext.ColumnWidth" ElementName="TableEditorRoot" /></MultiBinding></Setter.Value>
                                        </Setter>
                                        <Setter Property="Canvas.Top">
                                            <Setter.Value><MultiBinding Converter="{StaticResource IndexToPos}"><Binding Path="RowIndex" /><Binding Path="DataContext.RowHeight" ElementName="TableEditorRoot" /></MultiBinding></Setter.Value>
                                        </Setter>
                                        <Style.Triggers><DataTrigger Binding="{Binding IsMergedChild}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                 MinWidth="72" GotFocus="OnCellGotFocus" TextAlignment="Center" VerticalContentAlignment="Center" FontWeight="{Binding IsHeader, Converter={StaticResource BooleanToFontWeightConverter}}" Padding="4" Margin="0">
                                            <TextBox.Width><MultiBinding Converter="{StaticResource CellWidthConverter}"><Binding Path="DataContext.ColumnWidth" ElementName="TableEditorRoot" /><Binding Path="ColumnSpan" /></MultiBinding></TextBox.Width>
                                            <TextBox.Height><MultiBinding Converter="{StaticResource CellWidthConverter}"><Binding Path="DataContext.RowHeight" ElementName="TableEditorRoot" /><Binding Path="RowSpan" /></MultiBinding></TextBox.Height>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Style.Setters><Setter Property="Background" Value="{Binding Background}" /><Setter Property="BorderBrush" Value="{Binding BorderColor}" /><Setter Property="Foreground" Value="{Binding Foreground}" /></Style.Setters>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" /><Setter Property="BorderThickness" Value="2" /></Trigger>
                                                        <DataTrigger Binding="{Binding Background}" Value="Transparent"><Setter Property="Background" Value="Transparent" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding BorderColor}" Value=""><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Foreground}" Value=""><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                            <TextBox.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Unir com a Direita →" Command="{Binding DataContext.MergeCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Unir com a de Baixo ↓" Command="{Binding DataContext.MergeCellDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Dividir Célula (Split)" Command="{Binding DataContext.SplitCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="Remover esta Linha" Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Remover esta Coluna" Command="{Binding DataContext.RemoveColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                </ContextMenu>
                                            </TextBox.ContextMenu>
                                        </TextBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Image Element Template -->
        <DataTemplate DataType="{x:Type models:ImageElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Galeria de Imagens" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Título do Grupo" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Legenda Geral" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="16" Margin="0,0,0,20">
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Content="+ Adicionar Imagem" Command="{Binding DataContext.AddImagePlaceholderCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource AccentButton}" Margin="0" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,16,0" VerticalAlignment="Center" Background="{DynamicResource PanelBrush}">
                                    <Grid Width="40" Height="24">
                                        <Border Background="{DynamicResource AccentBrush}" Margin="2" CornerRadius="1">
                                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding LayoutMode}" Value="Single"><Setter Property="Visibility" Value="Visible" /></DataTrigger><DataTrigger Binding="{Binding LayoutMode}" Value="Grid1x1"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
                                        </Border>
                                        <UniformGrid Columns="2" Rows="1"><UniformGrid.Style><Style TargetType="UniformGrid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding LayoutMode}" Value="Grid2x1"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></UniformGrid.Style><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /></UniformGrid>
                                        <UniformGrid Columns="1" Rows="2"><UniformGrid.Style><Style TargetType="UniformGrid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding LayoutMode}" Value="Grid1x2"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></UniformGrid.Style><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /></UniformGrid>
                                        <UniformGrid Columns="2" Rows="2"><UniformGrid.Style><Style TargetType="UniformGrid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding LayoutMode}" Value="Grid2x2"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></UniformGrid.Style><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /><Border Background="{DynamicResource AccentBrush}" Margin="1" CornerRadius="1" /></UniformGrid>
                                    </Grid>
                                </Border>
                                <TextBlock Text="Layout das Imagens:" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" /><ComboBox ItemsSource="{Binding DataContext.ImageLayouts, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding LayoutMode}" Width="160" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding Images}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel><ItemsPanelTemplate><StackPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,16" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <Border Width="100" Height="80" CornerRadius="4" ClipToBounds="True" Background="{DynamicResource PanelAltBrush}"><Image Source="{Binding Path}" Stretch="UniformToFill" /></Border>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"><Button Content="↑" Command="{Binding DataContext.MoveImageUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="48" Margin="0,0,4,0" /><Button Content="↓" Command="{Binding DataContext.MoveImageDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="48" /></StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="16,0,16,0">
                                            <TextBlock Text="Ficheiro" Style="{StaticResource MutedLabel}" /><TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                                            <TextBlock Text="Legenda" Style="{StaticResource MutedLabel}" /><TextBox Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource DeleteButton}" Command="{Binding DataContext.RemoveImageCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- List Element Template -->
        <DataTemplate DataType="{x:Type models:ListElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel MaxWidth="850" HorizontalAlignment="Left">
                    <TextBlock Text="Editor de Listas" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" />
                    
                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="16" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Tipo de Estrutura" Style="{StaticResource MutedLabel}" />
                                <ComboBox ItemsSource="{Binding DataContext.ListKinds, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ListKind}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,20,0">
                                <TextBlock Text="Espaçamento (pt)" Style="{StaticResource MutedLabel}" />
                                <TextBox Text="{Binding ItemSpacing, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="2" Content="+ Novo Item" Command="{Binding DataContext.AddListItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource AccentButton}" VerticalAlignment="Bottom" Height="36" Padding="16,0" />
                        </Grid>
                    </Border>

                    <TextBlock Text="ITENS DA LISTA" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,12" />
                    <ListBox ItemsSource="{Binding Items}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                  Visibility="{Binding DataContext.SelectedElement.ListKind, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Checklist}" 
                                                  VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="Transparent" BorderThickness="0" FontSize="14" Padding="0" VerticalContentAlignment="Center" />
                                        <Button Grid.Column="2" Style="{StaticResource DeleteButton}" Command="{Binding DataContext.RemoveListItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" 
                                                Margin="12,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Text Element Template -->
        <DataTemplate DataType="{x:Type models:TextElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                    <TextBlock Text="Bloco de Texto e Secções" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" />
                    
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Título do Bloco / Nome da Secção" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="SemiBold" Padding="8,6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Nível Hierárquico" Style="{StaticResource MutedLabel}" />
                            <ComboBox ItemsSource="{Binding DataContext.SectionLevels, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Level}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Conteúdo do Documento (Suporta sintaxe LaTeX)" Style="{StaticResource MutedLabel}" Margin="4,10,0,8" />
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource PanelBrush}">
                        <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" 
                                 AcceptsReturn="True" AcceptsTab="True" MinHeight="500" 
                                 TextWrapping="Wrap" VerticalContentAlignment="Top" 
                                 Padding="20" FontSize="15" FontFamily="Segoe UI" 
                                 Background="Transparent" BorderThickness="0" />
                    </Border>
                    <TextBlock Text="Dica: Use \textbf{texto} para negrito, \textit{texto} para itálico." 
                               Style="{StaticResource MutedLabel}" FontStyle="Italic" Margin="8,12,0,0" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Theorem Template -->
        <DataTemplate DataType="{x:Type models:TheoremElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Teorema / Ambiente" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0"><TextBlock Text="Tipo" Style="{StaticResource MutedLabel}" /><ComboBox ItemsSource="{Binding DataContext.TheoremKinds, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding TheoremKind}" /></StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Subtítulo" Style="{StaticResource MutedLabel}" /><TextBox Text="{Binding Subtitle, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                    </Grid>
                    <TextBlock Text="Conteúdo" Style="{StaticResource MutedLabel}" /><TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="150" TextWrapping="Wrap" VerticalContentAlignment="Top" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Equation Template -->
        <DataTemplate DataType="{x:Type models:EquationElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Editor de Equações" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <TextBlock Text="Título" Style="{StaticResource MutedLabel}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />

                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="16" Margin="0,0,0,20">
                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabItem Header="Gregas">
                                <ScrollViewer MaxHeight="120" Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding DataContext.GreekLetters, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}" Command="{Binding DataContext.InsertEquationSymbolCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Command}" Margin="2" Padding="8,4" MinWidth="44" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Operadores">
                                <ScrollViewer MaxHeight="120" Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding DataContext.Operators, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}" Command="{Binding DataContext.InsertEquationSymbolCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Command}" Margin="2" Padding="8,4" MinWidth="44" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Relações">
                                <ScrollViewer MaxHeight="120" Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding DataContext.Relations, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}" Command="{Binding DataContext.InsertEquationSymbolCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Command}" Margin="2" Padding="8,4" MinWidth="44" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Estruturas">
                                <ScrollViewer MaxHeight="120" Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding DataContext.Structures, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}" Command="{Binding DataContext.InsertEquationSymbolCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Command}" Margin="2" Padding="8,4" MinWidth="44" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>

                    <TextBlock Text="Fórmula LaTeX" Style="{StaticResource MutedLabel}" />
                    <TextBox Text="{Binding Formula, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono" FontSize="16" AcceptsReturn="True" MinHeight="100" Padding="16" />
                    <CheckBox Content="Numerar Equação" IsChecked="{Binding IsNumbered}" Margin="0,16,0,16" />
                    
                    <TextBlock Text="Pré-visualização" Style="{StaticResource MutedLabel}" Margin="0,0,0,8" />
                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="12" Padding="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding Formula}" FontSize="26" HorizontalAlignment="Center" FontStyle="Italic" Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Code Template -->
        <DataTemplate DataType="{x:Type models:CodeElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Snippet de Código" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Linguagem" Style="{StaticResource MutedLabel}" />
                            <ComboBox ItemsSource="{Binding DataContext.ProgrammingLanguages, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding Language}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                            <CheckBox Content="Números de Linha" IsChecked="{Binding ShowLineNumbers}" Margin="0,0,0,8" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Código" Style="{StaticResource MutedLabel}" />
                    <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono" FontSize="13" AcceptsReturn="True" MinHeight="300" Padding="16" VerticalContentAlignment="Top" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Bibliography Template -->
        <DataTemplate DataType="{x:Type models:BibliographyElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Referências" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    <TextBlock Text="Estilo" Style="{StaticResource MutedLabel}" /><TextBox Text="{Binding Style, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />
                    <TextBox Text="{Binding BibContent, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono" AcceptsReturn="True" MinHeight="300" Padding="12" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Custom Code Template -->
        <DataTemplate DataType="{x:Type models:CustomCodeElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Código LaTeX Manual" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    <TextBox Text="{Binding RawLatex, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono" AcceptsReturn="True" MinHeight="300" Padding="12" />
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Chart Element Template -->
        <DataTemplate DataType="{x:Type models:ChartElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                    <TextBlock Text="Configuração de Gráfico" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" />
                    
                    <!-- General Settings -->
                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="CONFIGURAÇÃO GERAL" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Título do Gráfico" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Tipo de Gráfico" Style="{StaticResource MutedLabel}" />
                                    <ComboBox ItemsSource="{Binding DataContext.ChartKinds, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ChartKind}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <CheckBox Content="Mostrar Grelha" IsChecked="{Binding ShowGrid}" Margin="0,0,24,0" />
                                <CheckBox Content="Mostrar Legenda" IsChecked="{Binding ShowLegend}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Axis Labels -->
                    <Border Style="{StaticResource PanelBorder}" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="EIXOS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Rótulo Eixo X (Horizontal)" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding XLabel, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Rótulo Eixo Y (Vertical)" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding YLabel, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Data Definition -->
                    <TextBlock Text="GESTÃO DE DADOS" FontSize="16" FontWeight="SemiBold" Margin="4,10,0,12" />
                    
                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelBrush}" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Categorias" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding CategoriesRaw, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="12,10" FontSize="14" />
                            <TextBlock Text="Dica: Estas categorias aparecerão no eixo X." FontSize="11" FontStyle="Italic" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="SÉRIES (DADOS DO GRÁFICO)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                        <Button Content="+ Nova Série de Dados" 
                                Command="{Binding DataContext.AddChartSeriesCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                Style="{StaticResource AccentButton}" HorizontalAlignment="Right" Padding="16,6" />
                    </DockPanel>

                    <ListBox ItemsSource="{Binding Series}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12" Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Nome da Série" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold" />
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Margin="0,0,12,12">
                                            <TextBlock Text="Cor (LaTeX)" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Button Grid.Column="2" 
                                                Style="{StaticResource DeleteButton}"
                                                Command="{Binding DataContext.RemoveChartSeriesCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}"
                                                VerticalAlignment="Top" />

                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                                            <TextBlock Text="Valores numéricos" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding ValuesRaw, UpdateSourceTrigger=PropertyChanged}" 
                                                     Padding="10,8" FontFamily="Cascadia Mono" />
                                            <TextBlock Text="Garante que tens o mesmo número de valores que categorias." FontSize="11" FontStyle="Italic" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="32" /></Grid.RowDefinitions>

        <!-- Update Notification Bar -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🚀 Uma nova versão está disponível! " Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding UpdateVersion, StringFormat='Versão {0}'}" Foreground="White" Opacity="0.9" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Content="Descarregar Agora" Command="{Binding DownloadUpdateCommand}" Background="White" Foreground="{DynamicResource AccentBrush}" Padding="12,2" BorderThickness="0" Height="24" FontSize="11" />
            </StackPanel>
        </Border>

        <!-- Header -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,10,20,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,40,8">
                    <Image Source="pack://application:,,,/latexStudio.ico" Width="24" Height="24" Margin="0,0,12,0" /><TextBlock Text="Latex Studio" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="PRO" FontSize="10" FontWeight="Bold" Foreground="White" />
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                    <Button Content="Novo Projeto" Command="{Binding NewProjectCommand}" Margin="0,0,12,0" /><Button Content="Undo" Command="{Binding UndoCommand}" Width="70" Margin="0,0,4,0" /><Button Content="Redo" Command="{Binding RedoCommand}" Width="70" Margin="0,0,20,0" /><Button Content="Abrir" Command="{Binding OpenProjectCommand}" /><Button Content="Guardar" Command="{Binding SaveProjectCommand}" Style="{StaticResource AccentButton}" Margin="0,0,20,0" /><Button Content="Copiar" Command="{Binding CopyLatexCommand}" /><Button Content=".tex" Command="{Binding ExportTexCommand}" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Projects}" SelectedIndex="{Binding SelectedProjectIndex}" BorderThickness="0" Background="Transparent" VerticalAlignment="Bottom" Margin="0,8,0,-1">
                    <ListBox.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" BorderBrush="Transparent" BorderThickness="0,0,0,3" Background="Transparent" Padding="{TemplateBinding Padding}"><ContentPresenter /></Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" /><Setter Property="Foreground" Value="{DynamicResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></Trigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource PanelAltBrush}" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" FontSize="13" /></DataTemplate></ListBox.ItemTemplate>
                </ListBox>
                <RadioButton Content="Definições" IsChecked="{Binding IsSettingsOpen, Mode=OneWay}" Command="{Binding OpenSettingsCommand}" Style="{StaticResource {x:Type ToggleButton}}" Padding="16,8" VerticalAlignment="Bottom" Margin="12,0,0,1" BorderThickness="0,0,0,3" Background="Transparent">
                    <RadioButton.Template><ControlTemplate TargetType="RadioButton"><Border x:Name="border" BorderBrush="Transparent" BorderThickness="0,0,0,3" Background="Transparent" Padding="{TemplateBinding Padding}"><TextBlock Text="{TemplateBinding Content}" FontSize="13" /></Border><ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" /><Setter Property="Foreground" Value="{DynamicResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></Trigger></ControlTemplate.Triggers></ControlTemplate></RadioButton.Template>
                </RadioButton>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <!-- Settings Tab -->
            <Grid Panel.ZIndex="10" Background="{DynamicResource SurfaceBrush}">
                <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsProjectView}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
                <Grid.ColumnDefinitions><ColumnDefinition Width="300" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Background="{DynamicResource PanelAltBrush}" Padding="30">
                    <StackPanel><TextBlock Text="DEFINIÇÕES" FontSize="24" FontWeight="Bold" Margin="0,0,0,30" /><TextBlock Text="SISTEMA" Style="{StaticResource MutedLabel}" /><CheckBox Content="Modo Escuro" IsChecked="{Binding IsDarkTheme}" Checked="OnThemeChanged" Unchecked="OnThemeChanged" Margin="0,0,0,20" /><TextBlock Text="LATEX" Style="{StaticResource MutedLabel}" /><ComboBox ItemsSource="{Binding Engines}" SelectedItem="{Binding Document.Engine}" /></StackPanel>
                </Border>
                <ScrollViewer Grid.Column="1" Padding="50"><StackPanel MaxWidth="800"><TextBlock Text="Licença" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" /><Border Style="{StaticResource PanelBorder}" Padding="20"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Estado" Style="{StaticResource MutedLabel}" /><TextBlock Text="{Binding LicenseInfo}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" /></StackPanel><Button Grid.Column="1" Content="Validar Licença" Command="{Binding VerifyLicenseCommand}" /></Grid></Border><TextBlock Text="Caminho LaTeX" FontSize="20" FontWeight="SemiBold" Margin="0,40,0,20" /><TextBox Text="{Binding Document.CustomEnginePath, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></ScrollViewer>
            </Grid>

            <!-- Project Area -->
            <Grid>
                <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsProjectView}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="480" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource PanelAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="PROJETO" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,8" />
                            <Expander DockPanel.Dock="Top" Header="Metadados Académicos" IsExpanded="False" Margin="0,0,0,16">
                                <StackPanel Margin="10,10,0,0">
                                    <TextBlock Text="Título do Documento" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding Document.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Autor" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding Document.Author, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Instituição" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding Document.Institution, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Orientador" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding Document.Advisor, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Palavras-chave" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding Document.Keywords, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Resumo (Abstract)" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding Document.AbstractText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="80" VerticalContentAlignment="Top" />
                                    <TextBlock Text="Índices e Listas" Style="{StaticResource MutedLabel}" Margin="0,8,0,4" />
                                    <CheckBox Content="Índice Geral (ToC)" IsChecked="{Binding Document.IncludeTableOfContents}" />
                                    <CheckBox Content="Lista de Figuras (LoF)" IsChecked="{Binding Document.IncludeListOfFigures}" />
                                    <CheckBox Content="Lista de Tabelas (LoT)" IsChecked="{Binding Document.IncludeListOfTables}" />
                                </StackPanel>
                            </Expander>
                            <TextBlock DockPanel.Dock="Top" Text="ELEMENTOS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,12" />
                            <UniformGrid DockPanel.Dock="Top" Columns="2" Margin="0,0,0,16">
                                <Button Content="+ Tabela" Command="{Binding AddTableCommand}" />
                                <Button Content="+ Imagem" Command="{Binding AddImageCommand}" />
                                <Button Content="+ Lista" Command="{Binding AddListCommand}" />
                                <Button Content="+ Gráfico" Command="{Binding AddChartCommand}" />
                                <Button Content="+ Texto" Command="{Binding AddTextCommand}" />
                                <Button Content="+ Equação" Command="{Binding AddEquationCommand}" />
                                <Button Content="+ Código" Command="{Binding AddCodeCommand}" />
                                <Button Content="+ Teorema" Command="{Binding AddTheoremCommand}" />
                                <Button Content="+ Bib" Command="{Binding AddBibliographyCommand}" />
                                <Button Content="+ Manual" Command="{Binding AddCustomCodeCommand}" />
                            </UniformGrid>
                            <Button DockPanel.Dock="Bottom" Content="Remover Elemento" Command="{Binding RemoveSelectedCommand}" Margin="0,12,0,0" Foreground="Crimson" />
                            <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Button Grid.Column="0" Content="↑ Subir" Command="{Binding MoveUpCommand}" Margin="0,0,4,0" /><Button Grid.Column="1" Content="↓ Descer" Command="{Binding MoveDownCommand}" Margin="4,0,0,0" /></Grid>
                            <ListBox ItemsSource="{Binding Document.Elements}" SelectedItem="{Binding SelectedElement}" BorderThickness="0" Background="Transparent" MinHeight="200">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10,8" /><Setter Property="Margin" Value="0,2" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="border" CornerRadius="6" Background="Transparent" Padding="{TemplateBinding Padding}"><ContentPresenter /></Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}" /><Setter Property="Foreground" Value="White" /></Trigger>
                                                        <MultiTrigger><MultiTrigger.Conditions><Condition Property="IsMouseOver" Value="True" /><Condition Property="IsSelected" Value="False" /></MultiTrigger.Conditions><Setter TargetName="border" Property="Background" Value="{DynamicResource BorderBrush}" /></MultiTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <ContentControl Content="{Binding Kind}" Margin="0,0,10,0">
                                                <ContentControl.Resources>
                                                    <DataTemplate DataType="{x:Type models:DocumentElementKind}">
                                                        <TextBlock x:Name="Icon" Text="📄" />
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="Table"><Setter TargetName="Icon" Property="Text" Value="📋" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Image"><Setter TargetName="Icon" Property="Text" Value="🖼️" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="List"><Setter TargetName="Icon" Property="Text" Value="📝" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Chart"><Setter TargetName="Icon" Property="Text" Value="📊" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Text"><Setter TargetName="Icon" Property="Text" Value="📄" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Equation"><Setter TargetName="Icon" Property="Text" Value="∑" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Bibliography"><Setter TargetName="Icon" Property="Text" Value="📚" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Code"><Setter TargetName="Icon" Property="Text" Value="💻" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Theorem"><Setter TargetName="Icon" Property="Text" Value="⚖️" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="CustomCode"><Setter TargetName="Icon" Property="Text" Value="🛠️" /></DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ContentControl.Resources>
                                            </ContentControl>
                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </ScrollViewer>
                </Border>
                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" />
                <Grid Grid.Column="2" Background="{DynamicResource SurfaceBrush}"><Border Style="{StaticResource PaperBorder}" Margin="30"><ContentControl Content="{Binding SelectedElement}" /></Border></Grid>
                <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" />
                <Grid Grid.Column="4" Background="{DynamicResource SurfaceBrush}"><Border Style="{StaticResource PaperBorder}" Margin="20" Padding="30"><DockPanel><TextBlock DockPanel.Dock="Top" Text="CÓDIGO LATEX" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,16" /><TextBox Text="{Binding LatexCode, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Mono" FontSize="12" AcceptsReturn="True" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextBrush}" /></DockPanel></Border></Grid>
            </Grid>
        </Grid>
        <Border Grid.Row="3" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"><TextBlock Text="{Binding Status}" Foreground="{DynamicResource MutedTextBrush}" Margin="20,0" VerticalAlignment="Center" FontSize="11" /></Border>
    </Grid>
</Window>
