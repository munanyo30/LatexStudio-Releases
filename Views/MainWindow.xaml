<Window x:Class="LatexStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:LatexStudio.Models"
        xmlns:vm="clr-namespace:LatexStudio.ViewModels"
        xmlns:conv="clr-namespace:LatexStudio.Converters"
        Title="Latex Studio"
        Width="1420"
        Height="900"
        MinWidth="1040"
        MinHeight="720"
        AllowDrop="True"
        Drop="OnDrop"
        Background="{DynamicResource SurfaceBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:CellWidthConverter x:Key="CellWidthConverter" />
        <conv:IndexToPositionConverter x:Key="IndexToPos" />

        <!-- Table Element Template -->
        <DataTemplate DataType="{x:Type models:TableElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel x:Name="TableEditorRoot" MaxWidth="1000" HorizontalAlignment="Left">
                    <TextBlock Text="Propriedades da Tabela" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Título do Bloco" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Legenda (LaTeX)" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Estrutura e Células" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Clique numa célula para a selecionar. Use o botão direito para ações rápidas de união." Style="{StaticResource MutedLabel}" FontStyle="Italic" Margin="0,0,0,16" />
                    
                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="12" Margin="0,0,0,16">
                        <WrapPanel>
                            <Button Content="+ Linha" Command="{Binding DataContext.AddRowCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Insere uma linha abaixo da selecionada." />
                            <Button Content="- Linha" Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Remove a linha da célula selecionada." />
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0,14,0" Height="24" />
                            <Button Content="+ Coluna" Command="{Binding DataContext.AddColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Insere uma coluna à direita da selecionada." />
                            <Button Content="- Coluna" Command="{Binding DataContext.RemoveColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Remove a coluna da célula selecionada." />
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0,14,0" Height="24" />
                            <Button Content="Merge →" Command="{Binding DataContext.MergeCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" />
                            <Button Content="Merge ↓" Command="{Binding DataContext.MergeCellDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" />
                            <Button Content="Split" Command="{Binding DataContext.SplitCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </WrapPanel>
                    </Border>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Largura Célula" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding ColumnWidth, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Altura Linha" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding RowHeight, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <CheckBox Grid.Column="3" Content="Possui Cabeçalho (Header)" IsChecked="{Binding HasHeader}" VerticalAlignment="Bottom" Margin="0,0,0,16" />
                    </Grid>

                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="White">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MinHeight="300" MaxHeight="600">
                            <ItemsControl ItemsSource="{Binding AllCells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Background="Transparent" Width="{Binding TotalWidth}" Height="{Binding TotalHeight}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource IndexToPos}">
                                                    <Binding Path="ColumnIndex" />
                                                    <Binding Path="DataContext.ColumnWidth" ElementName="TableEditorRoot" />
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Canvas.Top">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource IndexToPos}">
                                                    <Binding Path="RowIndex" />
                                                    <Binding Path="DataContext.RowHeight" ElementName="TableEditorRoot" />
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMergedChild}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                 MinWidth="72"
                                                 GotFocus="OnCellGotFocus"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 FontWeight="{Binding IsHeader, Converter={StaticResource BooleanToFontWeightConverter}}"
                                                 Background="{Binding Background}"
                                                 BorderBrush="{Binding BorderColor}"
                                                 BorderThickness="1"
                                                 Padding="4"
                                                 Margin="0">
                                            <TextBox.Width>
                                                <MultiBinding Converter="{StaticResource CellWidthConverter}">
                                                    <Binding Path="DataContext.ColumnWidth" ElementName="TableEditorRoot" />
                                                    <Binding Path="ColumnSpan" />
                                                </MultiBinding>
                                            </TextBox.Width>
                                            <TextBox.Height>
                                                <MultiBinding Converter="{StaticResource CellWidthConverter}">
                                                    <Binding Path="DataContext.RowHeight" ElementName="TableEditorRoot" />
                                                    <Binding Path="RowSpan" />
                                                </MultiBinding>
                                            </TextBox.Height>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                            <TextBox.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Unir com a Direita →" Command="{Binding DataContext.MergeCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Unir com a de Baixo ↓" Command="{Binding DataContext.MergeCellDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Dividir Célula (Split)" Command="{Binding DataContext.SplitCellCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="Remover esta Linha" Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Remover esta Coluna" Command="{Binding DataContext.RemoveColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                </ContextMenu>
                                            </TextBox.ContextMenu>
                                        </TextBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Image Element Template -->
        <DataTemplate DataType="{x:Type models:ImageElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Galeria de Imagens" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Título do Grupo" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Legenda Geral" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="16" Margin="0,0,0,20">
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Content="+ Adicionar Imagem" Command="{Binding DataContext.AddImageFileCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Modo de Layout:" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ComboBox ItemsSource="{Binding DataContext.ImageLayouts, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding LayoutMode}" Width="160" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding Images}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,16,16" Width="360" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="100" Height="80" CornerRadius="4" ClipToBounds="True" Background="#F1F5F9">
                                            <Image Source="{Binding Path}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="Caminho do Ficheiro" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Legenda da Imagem" Style="{StaticResource MutedLabel}" />
                                                    <TextBox Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}" Margin="0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" Width="80">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SelectedElement.LayoutMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Custom">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="Largura (%)" Style="{StaticResource MutedLabel}" />
                                                    <TextBox Text="{Binding WidthPercent, UpdateSourceTrigger=PropertyChanged}" ToolTip="Ex: 0.45 para 45% da largura da página." />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- List Element Template -->
        <DataTemplate DataType="{x:Type models:ListElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                    <TextBlock Text="Lista de Itens" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <TextBlock Text="Título da Lista" Style="{StaticResource MutedLabel}" />
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Margin="0,0,0,20" />

                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="16" Margin="0,0,0,20">
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Content="+ Novo Item" Command="{Binding DataContext.AddListItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Estilo da Lista:" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ComboBox ItemsSource="{Binding DataContext.ListKinds, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ListKind}" Width="140" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding Items}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12" Padding="12">
                                    <StackPanel>
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold" Margin="0" />
                                        <ItemsControl ItemsSource="{Binding Children}" Margin="24,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- Chart Element Template -->
        <DataTemplate DataType="{x:Type models:ChartElement}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                    <TextBlock Text="Editor de Gráficos" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" />
                    
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Título do Gráfico" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Legenda (LaTeX)" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource PanelBorder}" Background="{DynamicResource PanelAltBrush}" Padding="16" Margin="0,0,0,24">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tipo de Gráfico:" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ComboBox ItemsSource="{Binding DataContext.ChartKinds, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ChartKind}" Width="160" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <CheckBox Content="Grelha" IsChecked="{Binding ShowGrid}" VerticalAlignment="Center" Margin="0,0,16,0" />
                                <CheckBox Content="Legenda" IsChecked="{Binding ShowLegend}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Etiqueta Eixo X" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding XLabel, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Etiqueta Eixo Y" Style="{StaticResource MutedLabel}" />
                            <TextBox Text="{Binding YLabel, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Dados das Séries" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Style="{StaticResource PanelBorder}" Padding="16">
                        <ItemsControl ItemsSource="{Binding Series}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,12">
                                                <TextBlock Text="Nome da Série:" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="200" HorizontalAlignment="Left" />
                                                <Border Width="20" Height="20" Background="{Binding Color}" CornerRadius="10" HorizontalAlignment="Right" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Values}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Height="140" VerticalAlignment="Bottom" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="30" Height="{Binding}" MinHeight="4" MaxHeight="130" Background="{DynamicResource AccentBrush}" CornerRadius="4,4,0,0" Margin="4,0" VerticalAlignment="Bottom" ToolTip="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- Modern Header -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Latex" FontSize="20" FontWeight="Light" Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Studio" FontSize="20" FontWeight="Bold" Margin="2,0,24,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Button Content="Undo" Command="{Binding UndoCommand}" Width="70" />
                        <Button Content="Redo" Command="{Binding RedoCommand}" Width="70" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Button Content="Abrir" Command="{Binding OpenProjectCommand}" />
                        <Button Content="Guardar" Command="{Binding SaveProjectCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Button Content="Copiar" Command="{Binding CopyLatexCommand}" />
                        <Button Content=".tex" Command="{Binding ExportTexCommand}" />
                        <Button Content="PDF" Command="{Binding ExportPdfCommand}" />
                    </StackPanel>
                    
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,20,0" Height="24" />
                    <CheckBox Content="Dark" IsChecked="{Binding IsDarkTheme}" Checked="OnThemeChanged" Unchecked="OnThemeChanged" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Tabs -->
                <ListBox ItemsSource="{Binding Projects}" SelectedIndex="{Binding SelectedProjectIndex}" BorderThickness="0" Background="Transparent" VerticalAlignment="Bottom" Margin="0,8,0,-1">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" BorderBrush="Transparent" BorderThickness="0,0,0,3" Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PanelAltBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="13" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="480" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource PanelAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ELEMENTOS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" Margin="4,0,0,12" />
                    
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Content="+ Tabela" Command="{Binding AddTableCommand}" Margin="0,0,4,8" />
                        <Button Grid.Row="0" Grid.Column="1" Content="+ Imagem" Command="{Binding AddImageCommand}" Margin="4,0,0,8" />
                        <Button Grid.Row="1" Grid.Column="0" Content="+ Lista" Command="{Binding AddListCommand}" Margin="0,0,4,0" />
                        <Button Grid.Row="1" Grid.Column="1" Content="+ Gráfico" Command="{Binding AddChartCommand}" Margin="4,0,0,0" />
                    </Grid>

                    <Button DockPanel.Dock="Bottom" Content="Remover Selecionado" Command="{Binding RemoveSelectedCommand}" Margin="0,12,0,0" />
                    
                    <ListBox ItemsSource="{Binding Document.Elements}" SelectedItem="{Binding SelectedElement}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="border" CornerRadius="6" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                        <Condition Property="IsSelected" Value="False" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource BorderBrush}" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ContentControl Content="{Binding Kind}" Margin="0,0,10,0">
                                        <ContentControl.Resources>
                                            <DataTemplate DataType="{x:Type models:DocumentElementKind}">
                                                <TextBlock x:Name="Icon" Text="📄" />
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="Table">
                                                        <Setter TargetName="Icon" Property="Text" Value="📋" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="Image">
                                                        <Setter TargetName="Icon" Property="Text" Value="🖼️" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="List">
                                                        <Setter TargetName="Icon" Property="Text" Value="📝" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="Chart">
                                                        <Setter TargetName="Icon" Property="Text" Value="📊" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ContentControl.Resources>
                                    </ContentControl>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" />

            <!-- Editor (Paper Style) -->
            <Grid Grid.Column="2" Background="{DynamicResource SurfaceBrush}">
                <Border Style="{StaticResource PaperBorder}" Margin="30">
                    <ContentControl Content="{Binding SelectedElement}" />
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" />

            <!-- Preview (Paper Style) -->
            <Grid Grid.Column="4" Background="{DynamicResource PanelAltBrush}">
                <Border Style="{StaticResource PaperBorder}" Margin="20" Padding="30">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                            <TextBlock Text="PREVIEW LATEX" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" />
                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,8,0,0" />
                        </StackPanel>
                        
                        <TextBox Text="{Binding LatexCode, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="12"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding Status}" Foreground="{DynamicResource MutedTextBrush}" Margin="20,0" VerticalAlignment="Center" FontSize="11" />
        </Border>
    </Grid>
</Window>
