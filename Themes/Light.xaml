<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="SurfaceColor">#FFF8FAFC</Color>
    <Color x:Key="PanelColor">#FFFFFFFF</Color>
    <Color x:Key="PanelAltColor">#FFF1F5F9</Color>
    <Color x:Key="TextColor">#FF0F172A</Color>
    <Color x:Key="MutedTextColor">#FF64748B</Color>
    <Color x:Key="AccentColor">#FF0D9488</Color>
    <Color x:Key="AccentHoverColor">#FF0F766E</Color>
    <Color x:Key="BorderColor">#FFE2E8F0</Color>
    <Color x:Key="ScrollBarThumbColor">#FFCBD5E1</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF94A3B8</Color>
    
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelAltBrush" Color="{StaticResource PanelAltColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}" />
</ResourceDictionary>
