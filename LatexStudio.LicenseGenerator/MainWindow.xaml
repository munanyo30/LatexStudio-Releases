<Window x:Class="LatexStudio.LicenseGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LatexStudio.LicenseGenerator"
        Title="Latex Studio - Painel de Licenciamento" Height="700" Width="600"
        WindowStartupLocation="CenterScreen" Background="#FFF8FAFC"
        WindowStyle="SingleBorderWindow">
    
    <Window.Resources>
        <local:PaidConverter x:Key="PaidConverter" />
        
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFF8FAFC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#FFF1F5F9" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0D9488" />
        <SolidColorBrush x:Key="TextBrush" Color="#FF0F172A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FF64748B" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE2E8F0" />

        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl Background="#F3F4F6" BorderThickness="0">
            <!-- Generator Tab -->
            <TabItem Header="Gerador" Padding="20,10">
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,24" Padding="0">
                        <StackPanel>
                            <TextBlock Text="GERADOR DE LICENÇAS" FontSize="24" FontWeight="Bold" Foreground="#111827" />
                            <TextBlock Text="Latex Studio PRO - Controle Administrativo" FontSize="14" Foreground="#6B7280" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="DADOS DO CLIENTE" Style="{StaticResource MutedLabel}" Foreground="#0D9488" Margin="0,0,0,16" />
                                    
                                    <TextBlock Text="Device ID (Hardware)" Style="{StaticResource MutedLabel}" />
                                    <TextBox x:Name="DeviceIdInput" Margin="0,0,0,16" Padding="8" />

                                    <TextBlock Text="Nome do Cliente / Empresa" Style="{StaticResource MutedLabel}" />
                                    <TextBox x:Name="ClientNameInput" Margin="0,0,0,16" Padding="8" />

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Duração da Licença" Style="{StaticResource MutedLabel}" />
                                            <ComboBox x:Name="DurationInput" SelectedIndex="2" Height="36">
                                                <ComboBoxItem Content="Trial (7 Dias)" />
                                                <ComboBoxItem Content="Trial (15 Dias)" />
                                                <ComboBoxItem Content="1 Mês (Mensal)" />
                                                <ComboBoxItem Content="3 Meses" />
                                                <ComboBoxItem Content="6 Meses" />
                                                <ComboBoxItem Content="1 Ano (Anual)" />
                                                <ComboBoxItem Content="Vitalícia (Lifetime)" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Preço (€)" Style="{StaticResource MutedLabel}" />
                                            <TextBox x:Name="PriceInput" Text="29.99" Padding="8" TextAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="EXPORTAÇÃO" Style="{StaticResource MutedLabel}" />
                                    <TextBox x:Name="LicenseOutput" IsReadOnly="True" Background="#F9FAFB" Padding="12" Height="60" TextWrapping="Wrap" BorderBrush="#D1D5DB" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="PROCESSAR E SALVAR NO BANCO" Click="OnGenerateLicense" Style="{StaticResource AccentButton}" Width="240" Height="44" />
                        <Button Content="SALVAR FICHEIRO .LIC" Click="OnSaveLicenseFile" Width="180" Height="44" Margin="12,0,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="Histórico e Vendas" Padding="20,10">
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="HISTÓRICO DE LICENÇAS" FontSize="24" FontWeight="Bold" Foreground="#111827" />
                        <TextBlock Text="Rastreio de pagamentos e prazos de expiração." FontSize="14" Foreground="#6B7280" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" ClipToBounds="True">
                        <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6" BorderThickness="0" RowHeight="45">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40" />
                                <DataGridTextColumn Header="Cliente" Binding="{Binding ClientName}" Width="*" />
                                <DataGridTextColumn Header="Expiração" Binding="{Binding ExpiryDate}" Width="100" />
                                <DataGridTextColumn Header="Preço" Binding="{Binding Price}" Width="80" />
                                <DataGridTemplateColumn Header="Estado" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaid}" Value="True"><Setter Property="Background" Value="#DCFCE7" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsPaid}" Value="False"><Setter Property="Background" Value="#FEE2E2" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding IsPaid, Converter={StaticResource PaidConverter}}" FontSize="10" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPaid}" Value="True"><Setter Property="Foreground" Value="#166534" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding IsPaid}" Value="False"><Setter Property="Foreground" Value="#991B1B" /></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Ações" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Toggle" Click="OnTogglePayment" Tag="{Binding}" FontSize="10" Padding="4,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Button Grid.Row="2" Content="EXPORTAR RELATÓRIO CSV" Click="OnExportCsv" HorizontalAlignment="Right" Margin="0,20,0,0" Padding="20,10" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
